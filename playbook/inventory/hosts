[ControlMachine]
localhost

[ControlMachine:vars]
ansible_connection=local
# Use the same Python interpreter that's running the Ansible playbook.
# This automatically uses pipx's Python when Ansible is installed via pipx.
ansible_python_interpreter={{ ansible_playbook_python }}

[firewalls]
firewall-01.lan.home

[firewalls:vars]
ansible_network_os=fortinet.fortios.fortios
ansible_connection=httpapi
ansible_httpapi_use_ssl=true
ansible_user=admin
vdom=root
# Set to true ONLY during initial bootstrap (before the SSL certificate is uploaded via 05-certificate-upload.yml).
# ansible_httpapi_validate_certs=false
